<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnyTone | Resource Download Center</title>
    <style>
        :root {
            --bg-canvas: #f8fafc;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --glass-bg: rgba(255, 255, 255, 0.8);
            --glass-border: rgba(226, 232, 240, 0.8);
            --img-container-bg: #f1f5f9;
            --btn-dark: #0f172a;
            --btn-dark-hover: #1e293b;
            --btn-light: #f1f5f9;
            --btn-light-hover: #e2e8f0;
            
            /* ✨ 核心：高级环境高亮特效光晕参数 */
            --glow-highlight: rgba(15, 23, 42, 0.08);
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.03);
            --transition-smooth: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-canvas);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* 顶部科技感流光微渐变 */
        body::before {
            content: "";
            position: absolute;
            top: -250px;
            left: 50%;
            transform: translateX(-50%);
            width: 1000px;
            height: 500px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.04) 0%, rgba(239, 68, 68, 0.03) 50%, rgba(255, 255, 255, 0) 100%);
            filter: blur(80px);
            z-index: 0;
            pointer-events: none;
        }

        /* 顶部品牌与Logo区 */
        .header {
            text-align: center;
            margin-top: 50px;
            z-index: 1;
            padding: 0 20px;
        }

        /* 👑 优化：Logo专属高级定位 */
        .brand-logo {
            max-height: 48px;
            width: auto;
            object-fit: contain;
            margin-bottom: 16px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.05));
        }

        .header h1 {
            font-size: 32px;
            font-weight: 800;
            margin: 0 0 8px 0;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #0f172a 0%, #475569 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header p {
            color: var(--text-muted);
            font-size: 15px;
            margin: 0;
            font-weight: 400;
            letter-spacing: -0.2px;
        }

        /* 🔍 搜索框高亮特效升级 */
        .search-container {
            width: 90%;
            max-width: 540px;
            margin: 35px 0 45px 0;
            z-index: 1;
        }

        .search-input {
            width: 100%;
            padding: 16px 24px;
            font-size: 16px;
            color: var(--text-main);
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 50px;
            outline: none;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-smooth);
            box-sizing: border-box;
        }

        /* 搜索框激活时的高亮发光圈 */
        .search-input:focus {
            border-color: #0f172a;
            box-shadow: 0 12px 30px -5px rgba(15, 23, 42, 0.08), 0 0 0 4px rgba(15, 23, 42, 0.04);
            transform: translateY(-1px);
        }

        /* 网格卡片容器 */
        .grid-container {
            width: 90%;
            max-width: 950px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 28px;
            padding-bottom: 80px;
            z-index: 1;
        }

        @media (min-width: 650px) {
            .grid-container {
                grid-template-columns: 1fr 1fr;
            }
        }

        /* 📦 产品卡片结构重构 */
        .product-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-smooth);
        }

        /* ✨ 核心高亮：悬浮时的环境微光与边缘锐化特效 */
        .product-card:hover {
            transform: translateY(-6px);
            border-color: rgba(15, 23, 42, 0.25);
            box-shadow: 0 30px 40px -15px var(--glow-highlight), 0 0 0 1px rgba(15, 23, 42, 0.02);
        }

        /* 🖼️ 新增：产品图片高级视窗 */
        .product-img-wrapper {
            width: 100%;
            height: 180px;
            background-color: var(--img-container-bg);
            border-radius: 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 1px solid rgba(0, 0, 0, 0.02);
            transition: var(--transition-smooth);
        }

        /* 悬浮卡片时，图片享受细腻的轻微放大特效 */
        .product-card:hover .product-img-wrapper img {
            transform: scale(1.04);
        }

        .product-img-wrapper img {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
            transition: var(--transition-smooth);
        }

        .product-info {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .product-info h3 {
            margin: 0 0 6px 0;
            font-size: 21px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .product-info .tag {
            align-self: flex-start;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            background: #e2e8f0;
            color: var(--text-muted);
            padding: 4px 10px;
            border-radius: 6px;
            margin-bottom: 20px;
        }

        /* 响应式多按钮底座 */
        .btn-group {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .btn {
            flex: 1;
            min-width: 100px;
            text-align: center;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            padding: 12px 6px;
            border-radius: 12px;
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            box-sizing: border-box;
        }

        .btn-manual {
            background-color: var(--btn-light);
            color: var(--text-main);
        }

        .btn-manual:hover {
            background-color: var(--btn-light-hover);
        }

        .btn-software {
            background-color: var(--btn-dark);
            color: #ffffff;
        }

        .btn-software:hover {
            background-color: var(--btn-dark-hover);
        }

        .no-results {
            text-align: center;
            color: var(--text-muted);
            grid-column: 1 / -1;
            padding: 60px 0;
            font-size: 15px;
            display: none;
            font-weight: 500;
        }
    </style>
</head>
