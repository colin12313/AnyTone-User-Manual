<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnyTone | Resource Download Center</title>
    <style>
        :root {
            --bg-canvas: #f8fafc;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --glass-bg: rgba(255, 255, 255, 0.85);
            --glass-border: rgba(226, 232, 240, 0.8);
            --img-container-bg: #f1f5f9;
            
            /* 🔵 全新明亮科技蓝色彩体系 */
            --brand-blue: #3b82f6;          
            --brand-blue-hover: #2563eb;    
            --tag-blue-bg: #e0f2fe;         
            --tag-blue-text: #0369a1;       
            
            /* 📄 Manual 专属商务蓝配置 */
            --btn-manual-bg: #dbeafe;       
            --btn-manual-text: #1e40af;     
            --btn-manual-hover: #bfdbfe;    
            
            --glow-highlight: rgba(59, 130, 246, 0.1); 
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.03);
            --transition-smooth: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-canvas);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* 顶部科技蓝流光微渐变特效 */
        body::before {
            content: "";
            position: absolute;
            top: -250px;
            left: 50%;
            transform: translateX(-50%);
            width: 1000px;
            height: 500px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, rgba(99, 102, 241, 0.04) 50%, rgba(255, 255, 255, 0) 100%);
            filter: blur(80px);
            z-index: 0;
            pointer-events: none;
        }

        /* 顶部品牌与Logo区 */
        .header {
            text-align: center;
            margin-top: 50px;
            z-index: 1;
            padding: 0 20px;
        }

        /* 👑 优化：Logo 尺寸放大至 100px，外加深层科技蓝晕，彰显大气 */
        .brand-logo {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 22px;
            margin-bottom: 20px;
            box-shadow: 0 12px 28px -4px rgba(59, 130, 246, 0.25), 0 2px 4px rgba(0,0,0,0.04);
            border: 1px solid rgba(59, 130, 246, 0.2);
            transition: var(--transition-smooth);
        }
        
        .brand-logo:hover {
            transform: scale(1.05) rotate(2deg);
        }

        .header h1 {
            font-size: 34px;
            font-weight: 800;
            margin: 0 0 8px 0;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #0f172a 0%, var(--brand-blue) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header p {
            color: var(--text-muted);
            font-size: 16px;
            margin: 0;
            font-weight: 400;
            letter-spacing: -0.2px;
        }

        /* 🔍 搜索框区 */
        .search-container {
            width: 90%;
            max-width: 540px;
            margin: 35px 0 45px 0;
            z-index: 1;
        }

        .search-input {
            width: 100%;
            padding: 16px 24px;
            font-size: 16px;
            color: var(--text-main);
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 50px;
            outline: none;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-smooth);
            box-sizing: border-box;
        }

        .search-input:focus {
            border-color: var(--brand-blue);
            box-shadow: 0 12px 30px -5px rgba(59, 130, 246, 0.15), 0 0 0 4px rgba(59, 130, 246, 0.05);
            transform: translateY(-1px);
        }

        /* 网格卡片容器 */
        .grid-container {
            width: 90%;
            max-width: 950px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 28px;
            padding-bottom: 80px;
            z-index: 1;
        }

        @media (min-width: 650px) {
            .grid-container {
                grid-template-columns: 1fr 1fr;
            }
        }

        /* 产品卡片结构 */
        .product-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-smooth);
        }

        .product-card:hover {
            transform: translateY(-6px);
            border-color: rgba(59, 130, 246, 0.35);
            box-shadow: 0 30px 45px -15px var(--glow-highlight), 0 0 0 1px rgba(59, 130, 246, 0.02);
        }

        /* 产品图片视窗容器 */
        .product-img-wrapper {
            width: 100%;
            height: 180px;
            background-color: var(--img-container-bg);
            border-radius: 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 1px solid rgba(0, 0, 0, 0.02);
            transition: var(--transition-smooth);
        }

        .product-card:hover .product-img-wrapper img {
            transform: scale(1.04);
        }

        .product-img-wrapper img {
            max-width: 92%;
            max-height: 92%;
            object-fit: contain;
            transition: var(--transition-smooth);
        }

        .product-info {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

